DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000

BACKEND_PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated origins — production example:
# CORS_ORIGIN=https://your-app.netlify.app
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
# Optional override: lax | strict | none (default: lax locally, none when COOKIE_SECURE=true)
# COOKIE_SAME_SITE=none

# When an uploaded file is missing (e.g. after Render restart), API and /uploads serve this path.
# Source image lives at backend/assets/static/post-fallback.png (committed to git).
POST_FALLBACK_IMAGE_URL=/static/post-fallback.png
