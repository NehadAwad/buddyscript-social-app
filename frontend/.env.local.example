# Local
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Vercel (Project Settings → Environment Variables):
# NEXT_PUBLIC_API_URL=https://buddyscript-social-app.onrender.com/api
# Primary fallback: backend static asset (backend/assets/static/post-fallback.png)
NEXT_PUBLIC_POST_FALLBACK_IMAGE=/static/post-fallback.png
# Last resort if backend is down: frontend/public/images/post-fallback.png
NEXT_PUBLIC_POST_LOCAL_FALLBACK_IMAGE=/images/post-fallback.png
